# Google Calendar API Configuration

# Your Google Calendar ID (e.g., hairbydekyi@gmail.com)
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# Base64 encoded service account key JSON
# To encode: cat service-account-key.json | base64
GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_json_here

#resend api key for email notifications
RESEND_API_KEY=re_api_key_here
